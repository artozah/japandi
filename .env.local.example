# Anthropic (chat intake)
ANTHROPIC_API_KEY=

# Clerk (auth) — from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# optional overrides
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres (via Vercel integration or https://neon.tech)
POSTGRES_URL=

# Vercel Blob — from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# Replicate
REPLICATE_API_TOKEN=
# Model identifier in "owner/name" form (e.g. black-forest-labs/flux-kontext-pro)
REPLICATE_MODEL=
# Webhook signing secret — only required in prod, fetch with:
#   curl -H "Authorization: Bearer $REPLICATE_API_TOKEN" https://api.replicate.com/v1/webhooks/default/secret
REPLICATE_WEBHOOK_SECRET=

# Public URL for webhook callbacks (e.g. https://japandi.vercel.app). Leave unset in dev.
NEXT_PUBLIC_APP_URL=
