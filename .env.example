# Copy this file to `.env.local` and fill in real values.

# --- Database (Neon / Postgres) ---
POSTGRES_URL=

# --- App URL (used for redirect URLs + webhook URLs) ---
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# --- Replicate (image generation) ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL=owner/model-name
REPLICATE_WEBHOOK_SECRET=

# --- Anthropic (chat + prompt enrichment) ---
ANTHROPIC_API_KEY=

# --- Paddle (billing) ---
# Client-side (shipped to the browser — safe as Paddle designs it)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# 'sandbox' or 'production'
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Price IDs from your Paddle dashboard — one per plan (pri_...)
NEXT_PUBLIC_PADDLE_PRICE_CUSTOM=
NEXT_PUBLIC_PADDLE_PRICE_STANDARD=
NEXT_PUBLIC_PADDLE_PRICE_PROFESSIONAL=
# Server-side webhook verification secret (from Paddle > Notifications)
PADDLE_WEBHOOK_SECRET=
# Server-side API key (Paddle > Developer tools > Authentication).
# Used to cancel subscriptions when a user deletes their account.
PADDLE_API_KEY=

# --- Feature flags ---
NEXT_PUBLIC_FF_TRY_IT_DEMO=false
NEXT_PUBLIC_FF_COMMUNITY_GALLERY=false
